# ===============================================================
# SERVER CONFIGURATION
# ===============================================================
PORT=8080
SPRING_APPLICATION_NAME=event-service

# ===============================================================
# DATABASE CONFIGURATION (MariaDB)
# ===============================================================
SPRING_DATASOURCE_URL=jdbc:mariadb://localhost:3306/event_management_db
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password

# ===============================================================
# JWT CONFIGURATION
# ===============================================================
JWT_SECRET=your_base64_encoded_secret_key_here

# ===============================================================
# KAFKA CONFIGURATION
# ===============================================================
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===============================================================
# REDIS CONFIGURATION
# ===============================================================
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# ===============================================================
# GEMINI AI CONFIGURATION (NEW)
# ===============================================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AQ.Ab8RN6JtyE9LqpqpBlgcUjht7cv2_ooNDGizm0Gn0IqI6j6NXQ

# ===============================================================
# EMAIL CONFIGURATION
# ===============================================================
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password

# ===============================================================
# NOTES
# ===============================================================
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env file to git
# 3. For Gemini API key, visit: https://makersuite.google.com/app/apikey
# 4. JWT_SECRET should be a strong base64 encoded string
# 5. For Gmail, use App Password, not your regular password
